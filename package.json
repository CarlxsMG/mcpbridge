{
  "name": "mcp-rest-bridge",
  "version": "1.0.0",
  "description": "Bun + TypeScript MCP gateway that bridges MCP clients to REST/OpenAPI backends and other MCP servers through one SSRF-safe, governed guard pipeline.",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/CarlxsMG/mcpbridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CarlxsMG/mcpbridge.git"
  },
  "bugs": {
    "url": "https://github.com/CarlxsMG/mcpbridge/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "api-gateway",
    "openapi",
    "rest",
    "bun",
    "ssrf",
    "reverse-proxy"
  ],
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "bun --watch src/index.ts",
    "dev:ui": "cd admin-ui && bun run dev",
    "dev:demo": "cd admin-ui && VITE_DEMO=true bun run dev",
    "dev:all": "bun scripts/dev-all.ts",
    "version:bump": "bun scripts/bump-version.ts",
    "start": "bun src/index.ts",
    "cli": "bun src/cli/index.ts",
    "build": "cd admin-ui && bun run build",
    "compile": "bun build --compile --minify --sourcemap ./src/index.ts --outfile dist/mcp-rest-bridge",
    "test": "bun test \"--path-ignore-patterns={admin-ui,e2e}/**\"",
    "test:coverage": "bun test --coverage \"--path-ignore-patterns={admin-ui,e2e}/**\"",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "typecheck:tools": "tsc --noEmit -p tsconfig.tools.json",
    "test:mutate": "stryker run",
    "check": "bun scripts/check-all.ts",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@scalar/openapi-parser": "^0.25.6",
    "ajv": "8.18.0",
    "ajv-formats": "^3.0.1",
    "express": "^5.1.0",
    "ipaddr.js": "^2.4.0",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.21.0",
    "yaml": "^2.7.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/express": "^5.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "bun-types": "1.3.11",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.10",
    "openapi-types": "^12.1.3",
    "prettier": "^3.9.4",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.62.1"
  }
}
