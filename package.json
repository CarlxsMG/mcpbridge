{
  "name": "mcp-rest-bridge",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:ui": "cd admin-ui && bun run dev",
    "dev:demo": "cd admin-ui && VITE_DEMO=true bun run dev",
    "dev:all": "bun scripts/dev-all.ts",
    "start": "bun src/index.ts",
    "cli": "bun src/cli/index.ts",
    "build": "cd admin-ui && bun run build",
    "compile": "bun build --compile --minify --sourcemap ./src/index.ts --outfile dist/mcp-rest-bridge",
    "test": "bun test \"--path-ignore-patterns={admin-ui,e2e}/**\"",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "test:mutate": "stryker run",
    "check": "bun scripts/check-all.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@scalar/openapi-parser": "^0.25.6",
    "@scalar/types": "^0.7.5",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "express": "^5.1.0",
    "ipaddr.js": "^2.4.0",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.21.0",
    "yaml": "^2.7.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/express": "^5.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "bun-types": "latest",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "openapi-types": "^12.1.3",
    "prettier": "^3.9.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.1"
  }
}
