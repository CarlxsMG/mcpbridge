# ─────────────────────────────────────────────────────────────────────────────
# MCP REST Bridge — example environment.
# Copy to `.env` (gitignored, Bun auto-loads it) and fill in real values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── First-boot admin (bootstrap) ────────────────────────────────────────────
# Creates the first admin user, but ONLY once — while the admin_users table is
# empty. After the user exists these are ignored (a warning is logged); you can
# then remove them and manage users from the UI. Password must be >= 12 chars.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-min-12-chars

# Static Bearer key(s) for the JSON admin API (/admin-api) — comma-separated.
# Optional: the Vue admin UI uses session login and works without this. Set it
# for CI / programmatic access. Generate one with e.g. `openssl rand -hex 24`.
ADMIN_API_KEYS=

# API key(s) MCP clients present to call tools (/mcp), comma-separated. Empty =
# no key required (combine with AUTH_DISABLED / per-tool guards as needed).
MCP_API_KEYS=

# ─── Dev/test auth bypass (dangerous — never in production) ───────────────────
# Global escape hatch: when true, ALL authentication is skipped — the admin API,
# the MCP data plane, and the /mcp control plane accept any caller. Strictly a
# local dev/test convenience; leave it unset (auth on) everywhere else.
#
# SECURITY: this fails CLOSED outside development — with AUTH_DISABLED=true and
# NODE_ENV != development the bridge REFUSES to start unless you also set
# ALLOW_UNSAFE_AUTH_DISABLED=true (the same opt-out pattern as the JWT-audience
# escape hatch below). Never set either in a real deployment.
# AUTH_DISABLED=false
# ALLOW_UNSAFE_AUTH_DISABLED=false

# ─── Production auth hardening (recommended once you rely on it) ──────────────
# Force the MCP data plane to fail CLOSED even before any key exists: with this
# unset AND no MCP_API_KEYS / managed keys / JWT configured, /mcp/:client,
# /mcp-custom/:bundle and the WS proxy accept ANY caller (a boot warning is logged).
# REQUIRE_MCP_AUTH=true
# Serve /docs (Swagger UI + the full OpenAPI spec) publicly. Off by default —
# /docs is admin-authenticated. Only set this where exposing the spec is intended.
# EXPOSE_DOCS_UNAUTHENTICATED=true

# ─── Network / CORS / proxy (production) ─────────────────────────────────────
# Allowlisted browser origins for the admin UI & admin API (comma-separated).
# '*' is refused when auth is enabled unless ALLOW_UNSAFE_CORS_WILDCARD=true.
# CORS_ORIGINS=https://admin.example.com
# Origins allowed to open an MCP session (Origin-header check), comma-separated.
# ALLOWED_ORIGINS=https://app.example.com
# Trust proxy hops for the correct client IP behind a reverse proxy: a hop count
# ('1'), a CIDR/preset list ('loopback,uniquelocal'), never bare 'true' in prod.
# TRUST_PROXY=1

# ─── Local dev runtime ───────────────────────────────────────────────────────
# Relaxes the startup guards (lets SESSION_COOKIE_SECURE=false etc. run without
# the ALLOW_UNSAFE_* escape hatches). Never set to development in production.
NODE_ENV=development
# Production hardening: set to "production" to make the bridge ABORT boot when
# any env var fails validation, instead of only logging warnings (the default).
# Recommended for real deployments so a misconfiguration fails fast; leave unset
# in dev. Any value other than "production" keeps the warn-only behavior.
# STRICT_CONFIG=production
# REQUIRED for admin-UI login over http://localhost — otherwise the session
# cookie is __Host-/Secure and the browser refuses to store it over plain http.
# In production (https) leave this true.
SESSION_COOKIE_SECURE=false
# Backend port. Keep in sync with the proxy target in admin-ui/vite.config.ts
# (dev:all forwards this automatically as BACKEND_PORT).
PORT=8790
# Admin-UI (Vite) dev-server port. Consumed by admin-ui/vite.config.ts.
UI_PORT=8791
# Let you register test upstreams pointing at loopback/private IPs (the SSRF
# guard blocks them otherwise). Fine locally; NEVER enable in production.
ALLOW_PRIVATE_IPS=true

# ─── Persistence ─────────────────────────────────────────────────────────────
# SQLite file path. Use :memory: for an ephemeral store (e.g. throwaway runs).
# DB_PATH=./data/mcp-bridge.db

# ─── Optional: encrypted upstream credentials ────────────────────────────────
# Enables storing per-client upstream secrets at rest (AES-256-GCM). Unset =
# secret storage disabled. Base64 32 bytes used directly; anything else is
# SHA-256'd to 32 bytes. Generate: `openssl rand -base64 32`.
# SECRET_ENCRYPTION_KEY=

# ─── Optional: pluggable external secrets manager ────────────────────────────
# Selects what encrypts/decrypts secrets at rest (OAuth2 client secrets,
# auto-provisioned MCP install-link keys, and future secret-storing features).
# 'local' (default) uses the built-in secret-box above — zero extra
# infrastructure. Set 'vault' if policy requires an external KMS; then Vault's
# Transit secrets engine does the encrypt/decrypt instead, and
# SECRET_ENCRYPTION_KEY is not used.
# SECRETS_PROVIDER=local
# VAULT_ADDR=https://vault.example.com:8200
# VAULT_TOKEN=
# VAULT_TRANSIT_KEY_NAME=mcp-rest-bridge

# ─── Optional: client-connection config generator ────────────────────────────
# Externally-reachable base URL for this gateway (e.g. behind a reverse proxy
# on a different host than the admin UI). Prefills the "Connect client" config
# generator (CLI `gateway connect` / admin-UI dialog) — unset means the CLI
# reuses its logged-in --url and the admin UI defaults to window.location.origin;
# either way the value stays editable at the call site.
# GATEWAY_PUBLIC_URL=https://gateway.example.com

# ─── Optional: value-feature flags ───────────────────────────────────────────
# ENABLE_SEARCH_TOOL=false            # hide the synthetic search_tools meta-tool (default on)
# AUDIT_SINK_URL=https://siem.example/ingest   # stream every audit event to a SIEM
# OTEL_EXPORTER_OTLP_ENDPOINT=http://collector:4318/v1/traces  # export tool-call spans
# RATE_LIMIT_SHARED=true              # SQLite-backed cross-instance rate counters (HA)
# REGISTRY_SYNC=true                  # reconcile the registry from SQLite across instances (HA)
# AUTO_GATE_WRITE_METHODS=true        # treat DELETE/PUT tools as sensitive by default, requiring step-up confirmation (default false)

# ─── Optional: proxy features (all opt-in per tool/client via the admin API) ──
# These are just the global knobs — each feature is enabled per tool/client.
# CACHE_MAX_ENTRIES=10000             # max in-memory cached GET responses (LRU-evicted)
# LB_TARGET_COOLDOWN_MS=30000         # cooldown before a failed load-balanced target is retried
# TRAFFIC_CAPTURE=true                # capture per-call args + result preview for the traffic explorer
# TRAFFIC_MAX_BODY_BYTES=8192         # max chars stored per captured result preview
# TRAFFIC_RETENTION_MS=604800000      # retain captured traffic for 7 days, then prune
# APPROVAL_WEBHOOK_URL=https://hooks.example/approvals  # notified when a call needs human approval
# MONITOR_WEBHOOK_URL=https://hooks.example/monitors    # notified on synthetic-monitor failure / drift
# OAUTH_TOKEN_TIMEOUT_MS=10000        # timeout for an outbound OAuth2 client-credentials token request

# ─── Optional: inbound OAuth2 / JWT auth (WebCrypto + JWKS, no dependency) ────
# Accept OAuth2/OIDC access tokens as an MCP credential, in addition to keys.
# Setting JWT_JWKS_URL also locks the surface down (like minting a managed key).
# JWT_JWKS_URL=https://issuer.example/.well-known/jwks.json
# JWT_ISSUER=https://issuer.example    # required `iss` claim (optional)
# JWT_AUDIENCE=mcp-rest-bridge         # required `aud` claim — see the warning below
# JWT_JWKS_CACHE_MS=600000             # JWKS cache TTL (ms)
#
# SECURITY: outside development, setting JWT_JWKS_URL *without* JWT_AUDIENCE is a
# fatal misconfiguration — with no audience binding, ANY token validly signed by
# a key in that JWKS is accepted, so in a shared IdP a token minted for an
# unrelated app is accepted as a gateway credential (a cross-audience privilege
# grant). The bridge refuses to start unless you set JWT_AUDIENCE (recommended)
# or explicitly opt out with ALLOW_UNSAFE_JWT_NO_AUDIENCE=true.
# ALLOW_UNSAFE_JWT_NO_AUDIENCE=false

# ─── Full reference ──────────────────────────────────────────────────────────
# This is a curated starter set of the common knobs, not every variable. The
# exhaustive, authoritative list (timeouts, circuit-breaker, session, rate-limit,
# tracing, alerts, HA, …) is the `config` object in `src/config.ts`; every var is
# also range-validated at boot by `src/config-schema.ts`. See the Configuration
# guide: https://aico-dot-team-code.github.io/mcpbridge/guide/configuration
