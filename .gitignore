# Dependencies
node_modules/

# Build output
dist/
*.js.map
*.tsbuildinfo

# VitePress docs site (built output + cache)
docs/.vitepress/dist/
docs/.vitepress/cache/

# Live demo build artifacts (regenerated in CI, copied into the site)
admin-ui/dist-demo/
docs/public/demo/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temp / logs
typecheck_out.txt
*.log

# SQLite (admin config store)
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Local secrets — Bun auto-loads these, never commit them
.env
.env.*
!.env.example
!.env.test

# Playwright MCP manual-testing artifacts
.playwright-mcp/

# Playwright e2e test run artifacts (playwright.config.ts)
/test-results/
/playwright-report/
/blob-report/

# AICO artifacts
.aico/*
!.aico/docs/
!.aico/data/

# Claude Code local state — per-user, never committed
.claude/
scripts/__pycache__/

# Stryker mutation testing — runs are reproducible via `bun run test:mutate`,
# so all report output (HTML + JSON) and per-run logs are local-only artifacts.
reports/
.stryker-tmp/
stryker.log
stryker.err
