# Dependencies
node_modules/

# Lockfiles
bun.lock

# Build output
dist/
*.js.map
*.tsbuildinfo

# VitePress docs site (built output + cache)
docs/.vitepress/dist/
docs/.vitepress/cache/

# Live demo build artifacts (regenerated in CI, copied into the site)
admin-ui/dist-demo/
docs/public/demo/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temp / logs
typecheck_out.txt
*.log

# SQLite (admin config store)
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Local secrets — Bun auto-loads these, never commit them
.env
.env.*
!.env.example

# Playwright MCP manual-testing artifacts
.playwright-mcp/

# AICO artifacts
.aico/*
!.aico/docs/
!.aico/data/
